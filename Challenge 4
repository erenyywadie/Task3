// Function that simulates loading data
function loadData(callback) {

    console.log("Loading data...");

    // Wait 3 seconds
    setTimeout(() => {
        console.log("Data loaded successfully!");

        // Execute callback after loading
        callback();
    }, 3000);
}

// Callback function
function finished() {
    console.log("Ready to use the data.");
}

// Run the program
loadData(finished);
------------
// Login function
function login(username, callback) {

    console.log(`Logging in as ${username}...`);

    // Simulate login delay
    setTimeout(() => {
        console.log("Login successful!");

        // Execute the next step
        callback();
    }, 2000);
}

// Callback function
function nextStep() {
    console.log("Redirecting to the Dashboard...");
}

// Run the authentication flow
login("Ereny", nextStep);
